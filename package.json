{
  "name": "context-router",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindlever-strategy/context-router.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@context-router/mcp-server",
    "build": "npm run db:generate && npm run build --workspace=@context-router/mcp-server && npm run build --workspace=@context-router/sdk && npm run build --workspace=@context-router/langgraph-adapter && npm run build --workspace=@context-router/crewai-adapter",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pretest": "npm run build",
    "test:mcp": "node scripts/mcp-smoke.mjs",
    "test:local": "node scripts/local-smoke.mjs",
    "test:integration": "npm run test:integration --workspace=@context-router/mcp-server",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "db:generate": "npm run db:generate --workspace=@context-router/mcp-server",
    "db:migrate": "npm run db:migrate --workspace=@context-router/mcp-server",
    "pack:check": "npm pack --dry-run --workspace=@context-router/mcp-server && npm pack --dry-run --workspace=@context-router/sdk && npm pack --dry-run --workspace=@context-router/langgraph-adapter && npm pack --dry-run --workspace=@context-router/crewai-adapter",
    "release:python:check": "node scripts/release-python-check.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
