# No DATABASE_URL is needed for the default SQLite storage.
# Set this only when opting into PostgreSQL:
# DATABASE_URL="postgresql://contextrouter:password@localhost:5432/contextrouter"
# Optional SQLite location override:
# CONTEXT_ROUTER_DATA_DIR="./.context-router-data"
# Optional explicit validation: sqlite or postgresql
# STORAGE_ENGINE="sqlite"
CONTEXT_ROUTER_OWNER_ID="local"
NODE_ENV="development"
