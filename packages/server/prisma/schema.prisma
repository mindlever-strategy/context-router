generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  engineType      = "client"
  moduleFormat    = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  schemas    Schema[]
  states     State[]
  checkpoints Checkpoint[]
  workflows  Workflow[]

  @@index([ownerId])
}

model Schema {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  version      Int      @default(1)
  fields       Json
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name, version])
  @@index([workspaceId])
}

model State {
  id           String   @id @default(uuid())
  workspaceId  String
  workflowId   String
  key          String
  value        Json
  updatedAt    DateTime @updatedAt
  version      Int      @default(1)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow  Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
  @@index([workspaceId])
  @@index([workflowId])
}

model Checkpoint {
  id           String   @id @default(uuid())
  workspaceId  String
  workflowId   String
  snapshot     Json
  label        String?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow  Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workflowId])
}

model Workflow {
  id            String         @id @default(uuid())
  workspaceId   String
  status        WorkflowStatus @default(RUNNING)
  createdAt     DateTime       @default(now())
  completedAt   DateTime?
  failureReason String?

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  states     State[]
  checkpoints Checkpoint[]

  @@index([workspaceId])
  @@index([status])
}

enum WorkflowStatus {
  RUNNING
  COMPLETED
  FAILED
}
