{
  "name": "@context-router/mcp-server",
  "version": "0.1.0",
  "description": "Local MCP server for structured multi-agent workflow state, checkpoints, and handoffs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-router-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "prisma",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindlever-strategy/context-router.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/mindlever-strategy/context-router#readme",
  "bugs": {
    "url": "https://github.com/mindlever-strategy/context-router/issues"
  },
  "keywords": [
    "mcp",
    "agents",
    "state-management",
    "checkpoints",
    "postgresql"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rimraf dist && tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run --exclude src/integration.test.ts",
    "test:integration": "vitest run src/integration.test.ts",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "prepack": "npm run db:generate && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.5",
    "prisma": "^7.8.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
